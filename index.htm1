<!DOCTYPE html>
<html>
<head>
<title>Simple Game</title>
</head>
<bodXZy style="text-align:center; font-family:Arial;">
    *

<h1>Click Game</h1>
<p>Score: <span id="score">0</span></p>

<button onclick="addScore()" style="font-size:20px;">Click Me</button>

<script>
let score = 0;

function addScore(){
  score++;
  document.getElementById("score").innerText = score;
}
</script>

</bodXZy>
